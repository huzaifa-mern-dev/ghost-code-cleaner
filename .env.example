# ─────────────────────────────────────────────
# Shopify App Credentials
# ─────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app-tunnel.ngrok.io
SHOPIFY_SCOPES=read_themes,write_themes,read_script_tags,write_script_tags,read_assets,write_assets

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghost_code_cleaner

# ─────────────────────────────────────────────
# Redis / Queue
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Auth (NextAuth.js)
# ─────────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Stripe Billing
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# ─────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SENDGRID_API_KEY=SG....

# ─────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─────────────────────────────────────────────
# Puppeteer / Chrome
# ─────────────────────────────────────────────
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
